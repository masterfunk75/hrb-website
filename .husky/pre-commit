# Ce hook est exécuté par sh (POSIX) : on n'y source PAS nvm (nvm.sh n'est pas
# compatible sh). On ajoute Node 24 (installé via nvm) en tête de PATH, sh-safe,
# pour que le hook marche même si tu commits depuis un shell en Node 14.
for d in "$HOME"/.nvm/versions/node/v24.*/bin; do
  if [ -d "$d" ]; then PATH="$d:$PATH"; fi
done
export PATH

# 1) Lint + format sur les fichiers indexés   2) Type-check du projet
npx lint-staged && npm run typecheck
